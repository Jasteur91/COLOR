# Projet Supabase : Settings → API
# URL du projet : https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Clé « anon » / « publishable » uniquement (jamais la service role ni sb_secret_*)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optionnel : URI Postgres (Settings → Database) pour npm run db:apply
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres

# Optionnel : compte Google AdSense pour injecter la balise
# <meta name="google-adsense-account" content="..."> dans le <head> global
# Exemple: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADSENSE_ACCOUNT=
